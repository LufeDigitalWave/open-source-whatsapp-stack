# ──────────────────────────────────────────────────────────────────────────────
# Open Source WhatsApp Business Stack — Environment Variables
# Copy this file to .env and fill in your values before running setup.sh
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# Your base domain. Services will be exposed at:
#   chatwoot.DOMAIN, n8n.DOMAIN, evolution.DOMAIN, traefik.DOMAIN
DOMAIN=yourdomain.com

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Email used for ACME certificate registration and expiry notifications
ACME_EMAIL=your@email.com

# ── Traefik Dashboard ─────────────────────────────────────────────────────────
# Basic auth for the Traefik dashboard (traefik.DOMAIN)
# Generate with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$examplehashedpassword

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=whatsapp
# Use a strong, random password (minimum 32 characters)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MINIMUM
POSTGRES_DB=whatsapp_stack

# ── Redis ─────────────────────────────────────────────────────────────────────
# Internal connection string — do not change unless you move Redis to an
# external host
REDIS_URL=redis://redis:6379

# ── Chatwoot ──────────────────────────────────────────────────────────────────
# Must be exactly 64 hex characters. Generate with:
#   openssl rand -hex 32
CHATWOOT_SECRET_KEY_BASE=CHANGE_ME_64_HEX_CHARS_GENERATE_WITH_OPENSSL_RAND_HEX_32

# SMTP settings for email notifications (account invites, password reset, etc.)
CHATWOOT_SMTP_ADDRESS=smtp.gmail.com
CHATWOOT_SMTP_PORT=587
CHATWOOT_SMTP_USERNAME=your@gmail.com
# For Gmail, use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
CHATWOOT_SMTP_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD

# ── n8n ───────────────────────────────────────────────────────────────────────
# Credentials to access the n8n web interface
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# Encryption key for stored credentials inside n8n workflows.
# Must be exactly 32 characters. Generate with:
#   openssl rand -base64 24 | head -c 32
N8N_ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARACTERS_

# ── Evolution API ─────────────────────────────────────────────────────────────
# Global API key — used to authenticate all requests to Evolution API.
# Generate with: openssl rand -hex 16
AUTHENTICATION_API_KEY=CHANGE_ME_EVOLUTION_GLOBAL_API_KEY

# ──────────────────────────────────────────────────────────────────────────────
# Security checklist before going live:
#   [ ] All CHANGE_ME values replaced with strong random secrets
#   [ ] .env file NOT committed to version control (.gitignore covers this)
#   [ ] VPS firewall allows only ports 80, 443, and 22 (SSH)
#   [ ] ENABLE_ACCOUNT_SIGNUP=false in docker-compose.yml (default)
# ──────────────────────────────────────────────────────────────────────────────
